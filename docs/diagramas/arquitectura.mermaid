
flowchart TB
    subgraph Cliente["Cliente"]
        CD["Claude Desktop"]
        API["API Anthropic<br/>(alternativa)"]
    end

    subgraph Agente["Agente"]
        A["Claude decide qué tool usar<br/>según la pregunta"]
    end

    subgraph MCP["Servidor MCP — mcp-server/server.py"]
        T1["consultar_grafo<br/>specs, topología, candidatas"]
        T2["calcular_financiero<br/>payback, ROI, VAN"]
        T3["detectar_cuello_botella<br/>capacidad efectiva empírica"]
        T4["generar_informe<br/>docx corporativo"]
        T5["consultar_manual_tecnico<br/>RAG índice vectorial"]
    end

    subgraph Datos["Neo4j — Knowledge Graph"]
        N1[("Linea / Estacion / Maquina<br/>/ MaquinaCandidata")]
        N2[("RegistroProduccion<br/>histórico de producción")]
        N4[("ManualChunk<br/>+ índice vectorial")]
    end

    subgraph Salida["Salidas"]
        RESP["Respuesta en chat"]
        DOCX["Informe .docx"]
    end

    CD --> A
    API -.-> A
    A --> T1 & T2 & T3 & T4 & T5

    T1 --> N1
    T3 --> N1
    T3 --> N2
    T4 --> N1
    T4 --> N2
    T5 --> N4

    T1 & T2 & T3 & T5 --> RESP
    T4 --> DOCX

